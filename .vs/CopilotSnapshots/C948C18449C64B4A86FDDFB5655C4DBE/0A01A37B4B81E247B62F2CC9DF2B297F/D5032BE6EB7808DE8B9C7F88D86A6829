/**
 * EventDetailPage - Trang chi tiết sự kiện
 *
 * Requirements: 3.1, 3.2, 3.3, 3.4, 4.1, 4.2, 4.3, 5.1
 */

import { useState, useEffect, useCallback } from "react";
import { useParams, useNavigate } from "react-router-dom";
import apiClient from "../utils/apiClient";
import Toast from "../components/ui/Toast";
import { useAuth } from "../context/AuthContext";

export default function EventDetailPage() {
  const { id: eventId } = useParams();
  const navigate = useNavigate();
  const { user } = useAuth();
  const [event, setEvent] = useState(null);
  const [isLoading, setIsLoading] = useState(true);
  const [toast, setToast] = useState(null);

  const isManager = user?.role === 'Admin' || user?.role === 'Cán bộ' || user?.email === 'tho.nh@ute.udn.vn';

  const fetchEvent = useCallback(async () => {
    setIsLoading(true);
    try {
      const response = await apiClient.get(`/api/events/${eventId}`);
      setEvent(response.data.data);
    } catch (err) {
      console.error(err);
    } finally {
      setIsLoading(false);
    }
  }, [eventId]);

  useEffect(() => { fetchEvent(); }, [fetchEvent]);

  const downloadExport = async (url, filename) => {
    try {
      const res = await apiClient.get(url, { responseType: 'blob' });
      const blob = new Blob([res.data], { type: res.headers['content-type'] || 'text/csv' });
      const link = document.createElement('a');
      link.href = window.URL.createObjectURL(blob);
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
    } catch (err) {
      console.error(err);
      throw err;
    }
  };

  const handleExportExcel = async () => {
    try {
      await downloadExport(`/api/events/${eventId}/participants/export`, `DS_DangKy_${eventId}.csv`);
      setToast({ message: "Đã xuất báo cáo thành công!", type: "success" });
    } catch (err) {
      setToast({ message: "Lỗi hệ thống khi xuất file", type: "error" });
    }
  };

  if (isLoading) return <div className="p-20 text-center text-indigo-600 font-bold animate-pulse">ĐANG TẢI...</div>;
  if (!event) return <div className="p-20 text-center text-red-500 font-bold">KHÔNG TÌM THẤY SỰ KIỆN</div>;

  return (
    <div className="min-h-screen bg-slate-100 flex justify-center py-10 px-4 font-sans">
      <div className="w-full max-w-xl">
        <button onClick={() => navigate("/")} className="mb-4 text-[10px] font-black text-slate-400 hover:text-indigo-600 flex items-center gap-1 transition-colors uppercase tracking-widest">
          <svg className="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" strokeWidth="4"><path d="M15 19l-7-7 7-7"/></svg> Quay lại
        </button>

        <div className="bg-white rounded-[40px] shadow-2xl overflow-hidden border border-slate-200">
          {/* Banner Header - Đúng như ảnh mẫu */}
          <div className="py-10 bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-center px-6">
             <p className="text-[10px] uppercase tracking-[0.4em] font-bold opacity-80 mb-2">THÔNG TIN CHI TIẾT SỰ KIỆN</p>
             <h2 className="font-black text-xl sm:text-2xl uppercase leading-tight tracking-wide">{event.tenDVQL || 'Đoàn Thanh niên - Hội Sinh viên'}</h2>
          </div>

          <div className="p-8 sm:p-12">
            <div className="mb-8">
               <span className="inline-block px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase mb-3 border border-indigo-100">{event.tenCLB}</span>
               <h1 className="text-4xl font-black text-slate-900 leading-tight mb-3 tracking-tight">{event.tenSK}</h1>
               <div className="w-16 h-1.5 bg-indigo-600 rounded-full"></div>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
              <div className="p-5 bg-slate-50/50 rounded-3xl border border-slate-100 flex items-center gap-4">
                <div className="w-10 h-10 bg-white rounded-2xl shadow-sm flex items-center justify-center text-indigo-600 border border-slate-100">
                  <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" strokeWidth="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p className="text-[8px] uppercase font-black text-slate-400 tracking-widest mb-0.5">Thời gian bắt đầu</p>
                  <p className="text-[12px] font-bold text-slate-700 leading-none">{new Date(event.thoiGianBatDau).toLocaleString('vi-VN')}</p>
                </div>
              </div>
              <div className="p-5 bg-slate-50/50 rounded-3xl border border-slate-100 flex items-center gap-4">
                <div className="w-10 h-10 bg-white rounded-2xl shadow-sm flex items-center justify-center text-rose-500 border border-slate-100">
                  <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" strokeWidth="2"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p className="text-[8px] uppercase font-black text-slate-400 tracking-widest mb-0.5">Địa điểm tổ chức</p>
                  <p className="text-[12px] font-bold text-slate-700 leading-none">{event.diaDiem}</p>
                </div>
              </div>
            </div>

            <div className="mb-10">
               <h3 className="font-black text-slate-900 mb-4 flex items-center gap-2 uppercase text-[11px] tracking-widest">
                 <span className="w-1.5 h-4 bg-indigo-600 rounded-full"></span> NỘI DUNG & KỊCH BẢN
               </h3>
               <div className="text-slate-500 text-sm leading-relaxed p-7 rounded-[32px] bg-slate-50 border border-slate-100 italic relative">
                  <span className="absolute top-2 left-4 text-4xl text-slate-200 font-serif">“</span>
                  {event.moTa}
                  <span className="absolute bottom-[-10px] right-4 text-4xl text-slate-200 font-serif">”</span>
               </div>
            </div>

            <div className="flex flex-col sm:flex-row gap-4 pt-8 border-t border-slate-100">
              {isManager ? (
                <>
                  <button onClick={() => navigate(`/events/${eventId}/statistics`)} className="flex-1 py-4 bg-indigo-600 text-white rounded-2xl font-black hover:bg-indigo-700 transition-all text-[11px] flex items-center justify-center gap-2 shadow-xl shadow-indigo-100 uppercase tracking-wider">📊 THỐNG KÊ SỰ KIỆN</button>
                  <button onClick={handleExportExcel} className="flex-1 py-4 bg-emerald-600 text-white rounded-2xl font-black hover:bg-emerald-700 transition-all text-[11px] flex items-center justify-center gap-2 shadow-xl shadow-emerald-100 uppercase tracking-wider">📥 XUẤT BÁO CÁO (EXCEL)</button>
                </>
              ) : (
                <button disabled={event.soNguoiDaDangKy >= event.soNguoiToiDa} className={`w-full py-5 rounded-2xl font-black text-white text-sm shadow-xl transition-all ${event.soNguoiDaDangKy >= event.soNguoiToiDa ? 'bg-slate-300' : 'bg-indigo-600 hover:bg-indigo-700 shadow-indigo-200'}`} onClick={undefined}>
                  {event.soNguoiDaDangKy >= event.soNguoiToiDa ? 'SỰ KIỆN ĐÃ HẾT CHỖ' : 'ĐĂNG KÝ THAM GIA NGAY'}
                </button>
              )}
            </div>
          </div>
        </div>
      </div>
      {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}
    </div>
  );
}
