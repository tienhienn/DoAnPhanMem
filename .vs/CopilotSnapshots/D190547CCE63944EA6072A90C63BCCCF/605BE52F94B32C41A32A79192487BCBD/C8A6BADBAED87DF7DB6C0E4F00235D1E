import { useState, useEffect, useCallback } from "react";
import { useParams, useNavigate } from "react-router-dom";
import apiClient from "../utils/apiClient";
import Modal from "../components/ui/Modal";
import Toast from "../components/ui/Toast";
import { useAuth } from "../context/AuthContext";

export default function EventDetailPage() {
  const { id: eventId } = useParams();
  const navigate = useNavigate();
  const { user } = useAuth();
  
  const [event, setEvent] = useState(null);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState(null);
  const [toast, setToast] = useState(null);

  // Flexible role check: treat CTSV / Cán bộ / Admin / Quản trị as manager
  const isManagerRole = (role) => {
    if (!role) return false;
    const r = role.toLowerCase();
    return r.includes('admin') || r.includes('cán bộ') || r.includes('can bo') || r.includes('ctsv') || r.includes('phòng') || r.includes('quản trị') || r.includes('ban quản lý') || r.includes('ban quan ly');
  };

  // CẬP NHẬT: Cho phép cả Admin và Cán bộ truy cập tính năng quản trị
  const isManager = isManagerRole(user?.role);

  const fetchEvent = useCallback(async () => {
    setIsLoading(true);
    try {
      const response = await apiClient.get(`/api/events/${eventId}`);
      setEvent(response.data.data);
    } catch (err) {
      setError("Không thể tải thông tin sự kiện");
    } finally {
      setIsLoading(false);
    }
  }, [eventId]);

  useEffect(() => {
    fetchEvent();
  }, [fetchEvent]);

  const handleExportExcel = async () => {
    try {
      // Call backend export endpoint which returns CSV as attachment
      const resp = await apiClient.get(`/api/events/${eventId}/participants/export`, { responseType: 'blob' });
      const blob = new Blob([resp.data], { type: resp.headers['content-type'] || 'text/csv' });
      // Derive filename from content-disposition or fallback
      let fileName = `BaoCao_SuKien_${eventId}.csv`;
      const cd = resp.headers['content-disposition'];
      if (cd) {
        const m = cd.match(/filename="?([^";]+)"?/);
        if (m && m[1]) fileName = m[1];
      }
      const url = window.URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.setAttribute('download', fileName);
      document.body.appendChild(link);
      link.click();
      link.parentNode.removeChild(link);
      window.URL.revokeObjectURL(url);
      setToast({ message: 'Đã tải báo cáo', type: 'success' });
    } catch (err) {
      console.error(err);
      const status = err.response?.status;
      if (status === 403) setToast({ message: 'Bạn không có quyền xuất báo cáo', type: 'error' });
      else setToast({ message: 'Lỗi khi xuất báo cáo', type: 'error' });
    }
  };

  if (isLoading) return <div className="p-10 text-center">Đang tải...</div>;
  if (!event) return <div className="p-10 text-center">Sự kiện không tồn tại</div>;

  return (
    <div className="min-h-screen bg-slate-50 pb-10">
      <div className="max-w-3xl mx-auto px-4 pt-6">
        <button onClick={() => navigate("/")} className="text-sm text-slate-600 hover:text-indigo-600">← Quay lại</button>
        
        <div className="mt-6 bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
          <div className="h-48 bg-gradient-to-r from-indigo-500 to-purple-600 flex items-center justify-center">
             <span className="text-white text-4xl font-bold opacity-30">EVENT</span>
          </div>

          <div className="p-8">
            <h1 className="text-3xl font-bold text-slate-800 mb-2">{event.tenSK}</h1>
            <p className="text-indigo-600 font-medium mb-6">{event.tenCLB}</p>

            <div className="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8 text-sm">
              <div className="space-y-1">
                <p className="text-slate-500">Thời gian:</p>
                <p className="text-slate-800 font-semibold">{new Date(event.thoiGianBatDau).toLocaleString('vi-VN')}</p>
              </div>
              <div className="space-y-1">
                <p className="text-slate-500">Địa điểm:</p>
                <p className="text-slate-800 font-semibold">{event.diaDiem}</p>
              </div>
            </div>

            <div className="mb-8">
               <h2 className="font-bold text-slate-800 mb-2">Mô tả sự kiện:</h2>
               <p className="text-slate-600 whitespace-pre-line">{event.moTa}</p>
            </div>

            <div className="flex flex-col gap-4">
              {isManager ? (
                /* GIAO DIỆN CHO QUẢN TRỊ VIÊN & CÁN BỘ */
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 border-t pt-6">
                  <button
                    onClick={() => navigate(`/events/${eventId}/statistics`)}
                    className="py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition-all flex items-center justify-center gap-2"
                  >
                    📊 Thống kê sự kiện
                  </button>
                  <button
                    onClick={handleExportExcel}
                    className="py-3 bg-emerald-600 text-white rounded-xl font-bold hover:bg-emerald-700 transition-all flex items-center justify-center gap-2"
                  >
                    📥 Xuất báo cáo (Excel)
                  </button>
                </div>
              ) : (
                /* GIAO DIỆN CHO SINH VIÊN */
                <button
                  disabled={event.soNguoiDaDangKy >= event.soNguoiToiDa}
                  className={`py-3 rounded-xl font-bold text-white transition-all ${
                    event.soNguoiDaDangKy >= event.soNguoiToiDa ? 'bg-slate-400' : 'bg-indigo-600 hover:bg-indigo-700'
                  }`}
                >
                  {event.soNguoiDaDangKy >= event.soNguoiToiDa ? 'Sự kiện đã hết chỗ' : 'Đăng ký tham gia'}
                </button>
              )}
            </div>
          </div>
        </div>
      </div>

      {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}
    </div>
  );
}
