import { useState, useEffect, useCallback } from "react";
import { useParams, useNavigate } from "react-router-dom";
import * as XLSX from 'xlsx';
import apiClient from "../utils/apiClient";
import Modal from "../components/ui/Modal";
import Toast from "../components/ui/Toast";
import { useAuth } from "../context/AuthContext";

export default function EventDetailPage() {
  const { id: eventId } = useParams();
  const navigate = useNavigate();
  const { user } = useAuth();
  
  const [event, setEvent] = useState(null);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState(null);
  const [toast, setToast] = useState(null);

  // Kiểm tra tài khoản đặc biệt và đơn vị quản lý
  const isSpecialUser = user?.email === 'tho.nh@ute.udn.vn';
  
  const fetchEvent = useCallback(async () => {
    setIsLoading(true);
    try {
      const response = await apiClient.get(`/api/events/${eventId}`);
      setEvent(response.data.data);
    } catch (err) {
      setError("Không thể tải thông tin sự kiện");
    } finally {
      setIsLoading(false);
    }
  }, [eventId]);

  useEffect(() => {
    fetchEvent();
  }, [fetchEvent]);

  if (isLoading) return <div className="p-10 text-center text-slate-500">Đang tải dữ liệu...</div>;
  if (!event) return <div className="p-10 text-center text-red-500">Sự kiện không tồn tại</div>;

  const isCTSVEvent = event.tenDVQL === 'Phòng Công tác Sinh viên';

  return (
    <div className="min-h-screen bg-slate-50 pb-10">
      <div className="max-w-3xl mx-auto px-4 pt-6">
        <button onClick={() => navigate("/")} className="text-sm text-slate-600 hover:text-indigo-600 font-medium">
          ← Quay lại danh sách
        </button>
        
        <div className="mt-6 bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
          {/* Header Banner */}
          <div className="h-40 bg-gradient-to-r from-blue-700 to-indigo-800 flex flex-col items-center justify-center text-white">
             <p className="text-xs uppercase tracking-widest opacity-70 mb-1">Đơn vị quản lý</p>
             <p className="font-bold text-xl">{event.tenDVQL || 'HCMUTE'}</p>
          </div>

          <div className="p-8">
            <div className="mb-6">
               <h1 className="text-3xl font-extrabold text-slate-900 mb-2 leading-tight">{event.tenSK}</h1>
               <div className="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-xs font-bold border border-indigo-100">
                  {event.tenCLB}
               </div>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
              <div className="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                <p className="text-[10px] uppercase font-bold text-slate-400 mb-1 tracking-wider">Thời gian diễn ra</p>
                <p className="text-sm font-bold text-slate-700">{new Date(event.thoiGianBatDau).toLocaleString('vi-VN')}</p>
              </div>
              <div className="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                <p className="text-[10px] uppercase font-bold text-slate-400 mb-1 tracking-wider">Địa điểm tổ chức</p>
                <p className="text-sm font-bold text-slate-700">{event.diaDiem}</p>
              </div>
            </div>

            <div className="mb-10">
               <h2 className="font-bold text-slate-800 mb-3 text-lg">Giới thiệu sự kiện</h2>
               <div className="text-slate-600 leading-relaxed whitespace-pre-line bg-slate-50/50 p-5 rounded-2xl border border-dashed border-slate-200">
                  {event.moTa}
               </div>
            </div>

            {/* KHU VỰC NÚT ĐIỀU KHIỂN THEO YÊU CẦU */}
            <div className="border-t pt-8">
              {isSpecialUser && isCTSVEvent ? (
                <div className="space-y-4">
                  <div className="flex items-center gap-2 text-amber-600 bg-amber-50 p-3 rounded-xl border border-amber-100 mb-2">
                    <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clipRule="evenodd" /></svg>
                    <p className="text-xs font-semibold uppercase">Quyền hạn: Quản lý sự kiện Phòng CTSV</p>
                  </div>
                  <button
                    onClick={() => navigate(`/events/${eventId}/statistics`)}
                    className="w-full py-5 bg-indigo-600 text-white rounded-2xl font-black hover:bg-indigo-700 shadow-xl shadow-indigo-100 transition-all transform hover:-translate-y-1 flex items-center justify-center gap-3 text-lg"
                  >
                    Xem chi tiết sự kiện
                  </button>
                </div>
              ) : (
                /* Giao diện cho các user khác giữ nguyên để đảm bảo app không lỗi */
                <button
                  disabled={event.soNguoiDaDangKy >= event.soNguoiToiDa}
                  className={`w-full py-4 rounded-2xl font-bold text-white text-lg ${
                    event.soNguoiDaDangKy >= event.soNguoiToiDa ? 'bg-slate-300 cursor-not-allowed' : 'bg-blue-600 hover:bg-blue-700 shadow-lg shadow-blue-100'
                  }`}
                >
                  {event.soNguoiDaDangKy >= event.soNguoiToiDa ? 'Đã hết chỗ tham gia' : 'Đăng ký tham gia ngay'}
                </button>
              )}
            </div>
          </div>
        </div>
      </div>
      {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}
    </div>
  );
}
